# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google OAuth Credentials (for production login with Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SPREADSHEET_URL: Custom Google Sheets xlsx export or public URL to check first
SPREADSHEET_URL=""

# ADMIN_EMAILS: Comma-separated emails that are ALWAYS treated as super-admins.
# If left empty, the very first user to sign in automatically becomes the admin.
# Example: ADMIN_EMAILS="you@pw.live,coordinator@physicswallah.org"
ADMIN_EMAILS=""

# PORT: Port the server listens on (defaults to 3000 if unset).
PORT="3000"

# ---------------------------------------------------------------------------
# SETTINGS SPREADSHEET (separate from the student-data spreadsheet)
# Stores access control across three tabs: Admin | Teacher | Staff
# Each tab header row: Email | Name | Center
# ---------------------------------------------------------------------------
# Spreadsheet ID of the settings sheet (defaults to the built-in id if unset).
SETTINGS_SPREADSHEET_ID="1zuNphm7hQd7_8WJXXSOA-J3PgEk-mN-elqLyAOPnA94"

# To WRITE roles back to the sheet you need a Google Cloud service account:
#   1. Create a service account + JSON key in Google Cloud Console.
#   2. Enable the "Google Sheets API".
#   3. Share the settings spreadsheet with the service account email (Editor).
#   4. Provide credentials via EITHER the full JSON key...
GOOGLE_SERVICE_ACCOUNT_KEY=""
#   ...OR the email + private key separately (keep the \n escapes in the key):
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
# If no credentials are set, roles are stored locally (data/app-state.json) instead.

